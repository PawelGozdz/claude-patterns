{
  "name": "knowledge-retriever",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for semantic retrieval of internal knowledge (patterns, rules, code) — claude-patterns overlay-on-ECC",
  "bin": { "knowledge-retriever": "dist/index.js" },
  "scripts": {
    "build": "tsc",
    "index": "node dist/indexer.js",
    "index:code": "node dist/indexer.js --mode code",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^11.0.0",
    "sqlite-vec": "^0.1.6",
    "typescript": "^5.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0"
  }
}
