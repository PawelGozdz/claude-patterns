{
  "version": "3.0.0",
  "description": "Consolidated hooks configuration (Phase A simplification: 11 → 4)",
  "last_updated": "2026-02-08",

  "hooks": {
    "user-prompt-submit": {
      "enabled": true,
      "script": "hooks/user-prompt-submit.sh",
      "description": "Auto-delegate implementation requests to orchestrator",
      "triggers": ["UserPromptSubmit"],
      "blocking": false
    },
    "cost-optimizer": {
      "enabled": true,
      "script": "hooks/cost-optimizer.sh",
      "description": "Advisory cost optimization suggestions (PreToolUse)",
      "triggers": ["PreToolUse"],
      "blocking": false
    },
    "state-manager": {
      "enabled": true,
      "script": "hooks/state-manager.sh",
      "description": "Unified STATE.md management (show/check/init/update/complete)",
      "triggers": ["SessionStart", "ClearContext", "Bash"],
      "blocking": false,
      "notes": "Merged from: auto-state-manager + ensure-state-saved + state-banner"
    },
    "session-monitor": {
      "enabled": true,
      "script": "hooks/session-monitor.sh",
      "description": "Model usage tracking and periodic tips (PostToolUse/SessionEnd)",
      "triggers": ["PostToolUse", "SessionEnd"],
      "blocking": false,
      "notes": "Merged from: session-summary + periodic-visual-feedback + post-tool-use-feedback"
    }
  },

  "deprecated": {
    "location": "hooks/deprecated/",
    "files": [
      "auto-state-manager.sh",
      "ensure-state-saved.sh",
      "state-banner.sh",
      "session-summary.sh",
      "periodic-visual-feedback.sh",
      "post-tool-use-feedback.sh",
      "enforce-tool-restrictions.sh",
      "post-agent-update.sh",
      "post-tool-use-feedback-debug.sh"
    ]
  }
}
