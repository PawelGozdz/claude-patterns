{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "symlinkDirectories": ["node_modules", ".svelte-kit"]
  },
  "autoMode": {
    "environment": [
      "SvelteKit 2 + Svelte 5 web application with TypeScript and Tailwind.",
      "Use Svelte 5 runes ($state, $derived, $effect, $props) — NOT Svelte 4 syntax.",
      "Data fetching in load functions, mutations via form actions.",
      "Secrets only in +page.server.ts, never in +page.ts."
    ],
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(npm test *)",
      "Bash(npm run check *)",
      "Bash(npx svelte-check *)",
      "Bash(npx vitest *)"
    ],
    "soft_deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-edit-format.js\""
          }
        ],
        "description": "Auto-format after edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-edit-typecheck.js\""
          }
        ],
        "description": "TypeScript check after editing .ts/.svelte files"
      }
    ]
  }
}
