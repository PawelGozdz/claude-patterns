{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "symlinkDirectories": ["node_modules", ".next"]
  },
  "autoMode": {
    "environment": [
      "Next.js 16 App Router project with TypeScript and Tailwind CSS.",
      "Server Components by default, 'use client' only for interactivity.",
      "Cache Components with 'use cache' directive for caching.",
      "proxy.ts replaces middleware.ts for route protection."
    ],
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(pnpm test *)",
      "Bash(pnpm run lint *)",
      "Bash(pnpm tsc --noEmit *)",
      "Bash(npx next build *)"
    ],
    "soft_deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-edit-format.js\""
          }
        ],
        "description": "Auto-format after edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-edit-typecheck.js\""
          }
        ],
        "description": "TypeScript check after editing .ts/.tsx files"
      }
    ]
  }
}
