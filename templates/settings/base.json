{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "symlinkDirectories": ["node_modules"]
  },
  "autoMode": {
    "environment": [],
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "soft_deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  }
}
