# project.yml - Project configuration for CLAUDE.md generation
# Copy to: <project>/.claude/config/project.yml
# Then run: ~/projects/claude-patterns/scripts/generate-claude-md.sh

project:
  name: my-project
  description: "Short project description"

  # Stack profile determines which template sections are included
  # Available: nestjs-ddd, flutter-clean-arch, python (or omit for generic)
  stack_profile: nestjs-ddd

  # Language determines which rules/{language}/ to apply
  # Available: typescript, python, dart (or omit for common only)
  language: typescript

  # Agent profile hints which agent set/workflow best fits this project
  # Available: backend-ddd, backend-api, frontend-ui, content-creative, data-pipeline
  # agent_profile: backend-ddd

  stack: "NestJS, TypeScript, PostgreSQL"
  testing: "Vitest"

  # Additional fields are stack-specific (shown in project table)
  # Choose fields based on your stack_profile:
  #
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # NESTJS-DDD STACK:
  #   ddd_library: "@vytches/ddd"
  #   database: "PostgreSQL 15, PostGIS 3.3"
  #
  # FLUTTER STACK:
  #   state_management: "Riverpod"  # or "Bloc", "Provider", etc.
  #   platforms: "iOS, Android, Web"
  #
  # PYTHON STACK:
  #   framework: "FastAPI"  # or "Django", "Flask", etc.
  #   database: "PostgreSQL 15"  # or "MongoDB", "SQLite", etc.
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  ddd_library: "@vytches/ddd"
  database: "PostgreSQL 15, PostGIS 3.3"

# Which skill categories to include (per-project scoping)
# Only listed categories are symlinked into .claude/knowledge/skills/
skills:
  - security
  - testing
  - database
  - quality
  - optimization
  - decision-frameworks
  - orchestration
  - architecture
  - learning
  - meta
  # Available: security, testing, database, quality, optimization,
  # decision-frameworks, orchestration, architecture, learning, meta,
  # backend, frontend, infrastructure, marketing, finance
  #
  # marketing — adds the 41 vendored marketing skills (CRO, copy, SEO,
  # paid, email, growth, RevOps). Opt-in: only enable for projects that
  # actually do marketing work. Requires .agents/product-marketing-context.md
  # for best results — set it up via `/marketing` or `/product-marketing-context`.
  #
  # finance — adds the 84 vendored finance skills across 7 plugins.
  # PLUGIN GRANULAR: instead of `finance` (all 84), enable per-plugin:
  #   - finance/core               (3 skills, math foundations, REQUIRED if any other finance/* enabled)
  #   - finance/wealth-management  (32 skills, investment + portfolio + personal)
  #   - finance/compliance         (16 skills, SEC/FINRA, KYC, AML, Reg BI)
  #   - finance/advisory-practice  (12 skills, advisor workflows; needs core + wealth-management)
  #   - finance/trading-operations (9 skills, order/execution/settlement)
  #   - finance/client-operations  (8 skills, account lifecycle)
  #   - finance/data-integration   (4 skills, reference + market data)
  # See skills/finance/PLUGINS.md for the dependency graph.
  #
  # legal — adds 12 vendored legal skills (1 MIT + 11 Apache 2.0) for
  # contract review, NDA triage, GDPR/CCPA compliance, risk assessment.
  # Strongly recommended: create .agents/legal-context.md declaring your
  # jurisdiction (PL/EU/US/...), business form, regulated industry, and
  # whether you have internal counsel — without it, legal-strategist
  # will ask before non-conceptual analysis.
  # 30 additional legal skills exist upstream (mostly AGPL) — see
  # skills/legal/EXTERNAL.md for catalog with per-project install
  # instructions (NOT auto-installed because of license fragmentation).

contexts:
  - name: auth
    status: production
    tests: 279
    notes: "Full CQRS, OAuth, sessions"
  - name: authorization
    status: production
    tests: 226
    notes: "RBAC, custom permissions"
  - name: billing
    status: in-progress
    tests: 0
    notes: "Subscription management"

rules:
  - "NEVER import between contexts. Use ACL Registry."
  - "Test Pyramid: L1 ~50%, L2 ~30%, L3 ~20%."
  - "BUSINESS_RULES.yaml: Update IMMEDIATELY on code changes (YAML format, not .md)."
  - "Audit fields NEVER from request body - always from RequestContext."
  - "Cross-context calls via aclRegistry.getGlobalRequired() only."

cost:
  opus: "<30%"
  sonnet: "~55%"
  haiku: ">15%"

docs:
  - LOCALHERO_PRODUCT.md
  - LOCALHERO_BUSINESS.md
  - LOCALHERO_MARKETING.md

# Entry points (slash commands)
entry_points:
  orchestrate: "/o"
  scaffold: "/scaffold"
  progress: "/progress"
