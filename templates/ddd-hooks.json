{
  "$comment": "DDD enforcement hooks config — place in project root or .claude/ directory",

  "baseClasses": [
    { "file": "*.aggregate.ts", "extends": ["AggregateRoot<"], "label": "Aggregate" },
    { "file": "*.vo.ts", "extends": ["BaseValueObject<"], "label": "Value Object" },
    { "file": "*.entity.ts", "extends": ["BaseEntity<"], "label": "Entity" },
    {
      "file": "*.specification.ts",
      "extends": ["CompositeSpecification<", "AsyncCompositeSpecification<"],
      "label": "Specification"
    },
    {
      "file": "*/domain/**/*.event.ts",
      "extends": ["ProjectDomainEvent<"],
      "label": "Domain Event"
    },
    {
      "file": "*.integration-event.ts",
      "extends": ["IntegrationEvent"],
      "label": "Integration Event"
    },
    {
      "file": "*/application/commands/**/command.ts",
      "implements": ["ICommand"],
      "label": "Command"
    },
    {
      "file": "*/application/queries/**/*.query.ts",
      "implements": ["IQuery"],
      "label": "Query"
    },
    {
      "file": "*-command.kysely.repository.ts",
      "extends": ["BaseKyselyRepository<"],
      "label": "Command Repository"
    },
    {
      "file": "*-query.kysely.repository.ts",
      "label": "Query Repository",
      "forbidden": [
        {
          "pattern": "TransactionHost",
          "message": "Query repositories must NOT use TransactionHost — use @Inject(DATABASE_TOKEN) + Kysely<Database> instead"
        }
      ]
    }
  ],

  "purity": {
    "noThrowLayers": ["domain", "application"],
    "noInfraImportLayers": ["domain"],
    "forbiddenImports": ["infrastructure/", "@nestjs/", "typeorm", "kysely"]
  },

  "contextPath": "src/contexts",

  "nestjs": {
    "requireInjectDecorator": {
      "enabled": true,
      "filePatterns": [
        "*.handler.ts",
        "*.service.ts",
        "*.controller.ts",
        "*.guard.ts",
        "*.interceptor.ts",
        "*.pipe.ts",
        "*.filter.ts",
        "*.gateway.ts",
        "*.resolver.ts",
        "*.saga.ts"
      ]
    }
  }
}
