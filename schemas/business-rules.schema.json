{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Business Rules YAML v2.1",
  "description": "Schema for BUSINESS_RULES.yaml files (v2.1 format). See patterns/testing/business-rules-yaml-pattern.md",
  "type": "object",
  "required": ["metadata", "business_rules"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["context", "version", "created", "last_updated", "maintainer"],
      "additionalProperties": false,
      "properties": {
        "context": {
          "type": "string",
          "description": "Context name, e.g. 'neighborhood-economy/service-provider'"
        },
        "subdomain": {
          "type": "string",
          "description": "Optional subdomain name for DDD projects"
        },
        "version": {
          "type": "string",
          "pattern": "^2\\.\\d+$",
          "description": "Schema version, must be 2.x"
        },
        "created": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "last_updated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "maintainer": {
          "type": "string"
        },
        "adr_reference": {
          "type": "string",
          "description": "Optional link to Architecture Decision Record"
        },
        "notes": {
          "type": "string",
          "description": "Optional context-specific architectural notes (1-2 sentences)"
        },
        "test_pyramid": {
          "type": "object",
          "description": "Optional test coverage summary by pyramid level (L1_unit, L2_handler, L3_e2e, etc.)",
          "additionalProperties": {
            "type": ["string", "number"]
          }
        }
      }
    },
    "business_rules": {
      "type": "object",
      "patternProperties": {
        "^BR-[A-Z]{2,5}(-[A-Z]{2,6})?-\\d{3}$": {
          "$ref": "#/$defs/business_rule"
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "flows": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]+$": {
          "$ref": "#/$defs/flow"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "enforcement_target": {
      "type": "object",
      "required": ["class"],
      "additionalProperties": false,
      "properties": {
        "class": {
          "type": "string",
          "description": "Class name that enforces this rule"
        },
        "method": {
          "type": "string",
          "description": "Optional method name within the class"
        },
        "layer": {
          "type": "string",
          "enum": ["domain", "application", "infrastructure", "framework", "api"],
          "description": "Architectural layer where enforcement occurs"
        },
        "file": {
          "type": "string",
          "description": "Optional file path for explicit code location"
        }
      }
    },
    "business_rule": {
      "type": "object",
      "required": ["title", "description", "rationale", "enforcement", "category", "on_failure"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "maxLength": 80
        },
        "description": {
          "type": "string"
        },
        "rationale": {
          "type": "string",
          "description": "Business reason - highest documentation value"
        },
        "enforcement": {
          "type": "object",
          "required": ["primary"],
          "additionalProperties": false,
          "description": "Links rule to code — primary enforcement point plus optional additional enforcers",
          "properties": {
            "primary": {
              "$ref": "#/$defs/enforcement_target"
            },
            "secondary": {
              "$ref": "#/$defs/enforcement_target",
              "description": "Optional secondary enforcement (e.g., API schema validation)"
            },
            "additional": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Additional enforcement points as free-text references"
            },
            "notes": {
              "type": "string",
              "description": "Implementation notes about enforcement strategy"
            }
          }
        },
        "category": {
          "type": "string",
          "enum": ["validation", "authorization", "invariant", "policy", "guard"]
        },
        "on_failure": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["error_code"],
              "additionalProperties": false,
              "properties": {
                "error_code": {
                  "oneOf": [
                    { "type": "null" },
                    { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" }
                  ],
                  "description": "Error code constant, or null for internal-only failures"
                },
                "error_class": {
                  "type": "string",
                  "description": "Error/exception class name"
                },
                "http_status": {
                  "type": "integer",
                  "minimum": 400,
                  "maximum": 599,
                  "description": "HTTP status code for API responses"
                },
                "message": {
                  "type": "string",
                  "description": "Human-readable error message"
                },
                "notes": {
                  "type": "string",
                  "description": "Implementation notes about failure handling"
                }
              }
            }
          ]
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^BR-[A-Z]{2,5}(-[A-Z]{2,6})?-\\d{3}$"
          }
        },
        "on_success": {
          "type": "object",
          "properties": {
            "description": { "type": "string" }
          },
          "additionalProperties": false
        },
        "tests": {
          "type": "object",
          "description": "Test coverage mapping by pyramid level (L1_spec, L2_hdl, L3_api, etc.)",
          "additionalProperties": {
            "type": "string"
          }
        },
        "gherkin": {
          "type": "string",
          "description": "BDD scenario in Gherkin format (Given/When/Then)"
        },
        "deprecated": {
          "type": "boolean",
          "const": true
        },
        "deprecated_reason": {
          "type": "string"
        },
        "deprecated_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "flow": {
      "type": "object",
      "required": ["description", "endpoint", "handler", "steps"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "endpoint": {
          "type": "string",
          "description": "HTTP method + path, or INTERNAL/CRON prefix for non-HTTP flows"
        },
        "handler": {
          "type": "string"
        },
        "request_schema": {
          "type": "string",
          "description": "Zod schema class name - links to OpenAPI spec"
        },
        "response_schema": {
          "type": "string",
          "description": "Response DTO class name - links to OpenAPI spec"
        },
        "deprecated": {
          "type": "boolean",
          "description": "Mark flow as deprecated (kept for backward compatibility)"
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/flow_step" },
          "minItems": 1
        },
        "on_success": {
          "type": "object",
          "required": ["entity", "state"],
          "properties": {
            "entity": { "type": "string" },
            "state": { "type": "string" },
            "emits": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Domain events emitted on flow completion"
            },
            "next_possible_flows": {
              "type": "array",
              "items": { "type": "string" }
            },
            "response": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Response fields returned to the caller"
            },
            "notes": {
              "type": "string",
              "description": "Optional side effects, cascading behavior, etc."
            }
          },
          "additionalProperties": false
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["error_code", "from", "http_status"],
            "additionalProperties": false,
            "properties": {
              "error_code": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_]+$"
              },
              "from": {
                "type": "string",
                "description": "BR rule ID or flow step name that produces this error"
              },
              "http_status": {
                "type": "integer",
                "minimum": 400,
                "maximum": 599
              }
            }
          }
        }
      }
    },
    "flow_step": {
      "type": "object",
      "required": ["step"],
      "additionalProperties": false,
      "properties": {
        "step": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]+$"
        },
        "rule": {
          "type": "string",
          "pattern": "^BR-[A-Z]{2,5}(-[A-Z]{2,6})?-\\d{3}$"
        },
        "action": {
          "type": "string"
        },
        "on_failure": {
          "type": "string",
          "enum": ["rollback", "continue", "retry"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
