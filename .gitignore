# Global Claude Patterns Repository - .gitignore

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor Files
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Temporary Files
*.tmp
*.bak
*.log

# Local Testing
test-project/
sandbox/
scratch/

# Build Artifacts (if any scripts generate them)
*.pyc
__pycache__/
node_modules/

# Local Configuration (if users want to override)
local-config.yml
# Tooling dependencies
tooling/node_modules/
tooling/package-lock.json
.grantflow

# knowledge-retriever (RAG) runtime artifacts — NEVER commit (186MB+ Qdrant storage, deps, builds)
mcp-server/knowledge-retriever/node_modules/
mcp-server/knowledge-retriever/dist/
mcp-server/knowledge-retriever/volumes/qdrant/
mcp-server/knowledge-retriever/.knowledge/
